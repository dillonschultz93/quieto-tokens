{
  "name": "@quieto/tokens",
  "version": "0.2.1",
  "description": "CLI tool for generating complete, accessible design token systems.",
  "type": "module",
  "bin": {
    "quieto-tokens": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "notion:init": "node scripts/sync-to-notion.mjs --init",
    "notion:sync": "node scripts/sync-to-notion.mjs",
    "validate:sprint": "node scripts/validate-sprint-status.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dillonschultz93/quieto-tokens.git"
  },
  "keywords": [
    "design-tokens",
    "dtcg",
    "css-variables",
    "design-system",
    "cli"
  ],
  "author": "Dillon Schultz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dillonschultz93/quieto-tokens/issues"
  },
  "homepage": "https://github.com/dillonschultz93/quieto-tokens#readme",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@notionhq/client": "^5.18.0",
    "@quieto/engine": "^0.1.1",
    "dotenv": "^17.4.2",
    "style-dictionary": "^5.4.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@changesets/get-github-info": "^0.8.0"
  }
}
